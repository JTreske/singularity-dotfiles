[
  {
    "group": "Input Settings",
    "description": "",
    "settings": [
      {
        "name": "Keyboard Layout",
        "id": "variant_keyboard_layout",
        "instructions": "Choose your keyboard layout variant:",
        "file": "~/.config/hypr/conf/keyboard-layout.conf",
        "type": "files",
        "folder": "~/.config/hypr/conf/keyboard-layout",
        "mode": "replace",
        "checkpoint": "# variant #",
        "match": "source = ~/.config/hypr/conf/keyboard-layout/.*",
        "default": "de.conf"
      },
      {
        "name": "Input",
        "id": "variant_input",
        "instructions": "Choose your input variant:",
        "file": "~/.config/hypr/conf/input.conf",
        "type": "files",
        "folder": "~/.config/hypr/conf/input",
        "mode": "replace",
        "checkpoint": "# variant #",
        "match": "source = ~/.config/hypr/conf/input/.*",
        "default": "default.conf"
      },
      {
        "name": "Keybinding",
