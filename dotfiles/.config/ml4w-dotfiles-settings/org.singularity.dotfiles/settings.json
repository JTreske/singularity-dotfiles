  {
    "group": "Default Apps",
    "description": "Please setup your default apps.",
    "settings": [
      {
        "name": "Default Terminal Emulator",
        "id": "default_terminal",
        "instructions": "Enter the command to execute the terminal",
        "file": "~/.config/singularity/default-apps/terminal.sh",
        "type": "textfield",
        "mode": "replace",
        "checkpoint": "# variant #",
        "match": ".*",
        "default": "kitty \"$@\""
      },
      {
        "name": "Default Browser",
        "id": "default_browser",
        "instructions": "Enter the command to execute the browser",
        "file": "~/.config/singularity/default-apps/browser.sh",
        "type": "textfield",
        "mode": "overwrite",
        "default": ""
      },
      {
        "name": "Default File Manager",
        "id": "default_file_manager",
        "instructions": "Enter the command to execute the file_manager",
        "file": "~/.config/singularity/default-apps/file-manager.sh",
        "type": "textfield",
        "mode": "overwrite",
        "default": "nemo"
      },
      {
        "name": "Default Editor",
        "id": "default_editor",
        "instructions": "Enter the command to execute the editor",
        "file": "~/.config/singularity/default-apps/editor.sh",
        "type": "textfield",
        "mode": "overwrite",
        "default": "gnome-text-editor"
      },
      {
        "name": "Default Calculator",
        "id": "default_calculator",
        "instructions": "Enter the command to execute the calculator",
        "file": "~/.config/singularity/default-apps/calculator.sh",
        "type": "textfield",
        "mode": "overwrite",
        "default": "gnome-calculator"
